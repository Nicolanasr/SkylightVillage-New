# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git

# Supabase PostgreSQL connection string
# Find this in: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use the "Transaction" mode URL (port 6543) for Vercel serverless
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# Role Simulator — set to "true" in local dev, leave unset or "false" in production
NEXT_PUBLIC_SHOW_SIMULATOR="true"
